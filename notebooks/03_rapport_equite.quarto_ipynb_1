    "    on='sirene', how='inner'\n",
    ")\n",
    "\n",
    "print(f\"{len(fin_communes)} lignes de financement vers des communes de l'arrondissement\")\n",
    "print(f\"Montant total : {fin_communes['montant_sub'].sum():,.0f} €\")"

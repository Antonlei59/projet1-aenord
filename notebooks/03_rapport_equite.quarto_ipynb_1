   "source": [
    "analyse = sub_par_commune.merge(\n",
    "    population[['COM', 'Commune', 'PMUN']],\n",
    "    on='COM', how='left'\n",
    ")\n",
    "analyse['PMUN'] = pd.to_numeric(analyse['PMUN'], errors='coerce')\n",
    "\n",
    "# Totaux intra-arrondissement (communes avec données population)\n",
    "analyse_complete = analyse.dropna(subset=['PMUN']).copy()\n",
    "total_sub = analyse_complete['montant_recu'].sum()\n",
    "total_pop = analyse_complete['PMUN'].sum()\n",
    "\n",
    "analyse_complete['poids_demo']        = analyse_complete['PMUN'] / total_pop\n",
    "analyse_complete['montant_theorique'] = analyse_complete['poids_demo'] * total_sub\n",
    "analyse_complete['ecart']             = analyse_complete['montant_recu'] - analyse_complete['montant_theorique']\n",
    "analyse_complete['ecart_pct']         = (analyse_complete['ecart'] / analyse_complete['montant_theorique'] * 100).round(1)\n",
    "\n",
    "analyse_complete = analyse_complete.sort_values('ecart', ascending=False)\n",
    "\n",
    "# Affichage résumé\n",
    "cols = ['commune', 'PMUN', 'montant_recu', 'montant_theorique', 'ecart', 'ecart_pct']\n",
    "resume = analyse_complete[cols].copy()\n",
    "for col in ['montant_recu', 'montant_theorique', 'ecart']:\n",
    "    resume[col] = resume[col].apply(lambda x: f\"{x/1e6:.2f} M€\")\n",
    "resume['PMUN'] = resume['PMUN'].apply(lambda x: f\"{int(x):,}\")\n",
    "resume.columns = ['Commune', 'Population', 'Reçu', 'Quote-part théorique', 'Écart', 'Écart (%)']\n",
    "\n",
    "print(f\"Enveloppe totale analysée : {total_sub/1e6:.1f} M€  |  Population couverte : {int(total_pop):,} hab.\")\n",
    "resume.head(15)"
   ]
